PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173,http://localhost:5174
APP_NAME=LitFlow
APP_URL=http://localhost:5173
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_with_your_supabase_service_role_key
JWT_SECRET=replace_with_a_long_random_user_jwt_secret
JWT_EXPIRES_IN=7d
ADMIN_JWT_SECRET=replace_with_a_long_random_admin_jwt_secret
ADMIN_JWT_EXPIRES_IN=12h
ADMIN_SEED_EMAIL=replace_with_your_admin_email
ADMIN_SEED_PASSWORD=replace_with_a_strong_admin_password
ADMIN_SEED_NAME=LitFlow Admin
ADMIN_SEED_RECOVERY_ENABLED=false

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=LitFlow <no-reply@litflow.app>

SEMANTIC_SCHOLAR_API_KEY=
SEMANTIC_SCHOLAR_BASE_URL=https://api.semanticscholar.org/graph/v1

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_INPUT_COST_PER_1M=0.15
OPENAI_OUTPUT_COST_PER_1M=0.60

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_PRO_PLAN_ID=
RAZORPAY_SUBSCRIPTION_COUNT=12
